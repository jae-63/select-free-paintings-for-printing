# canvas_finder — example environment file
#
# INSTRUCTIONS:
#   1. Copy this file to .env  (which is gitignored)
#   2. Fill in your own keys
#   3. Never commit .env to version control
#
# cp config.example.env .env

# ---------------------------------------------------------------------------
# Europeana API key
# Free signup: https://apis.europeana.eu/api/apikey-form
# Optional — only needed if you use --sources europeana
# ---------------------------------------------------------------------------
EUROPEANA_API_KEY=your_europeana_key_here

# ---------------------------------------------------------------------------
# Anthropic API key
# Free tier available at: https://console.anthropic.com
# Optional — only needed for Claude vision oil-smoothness classification.
# If absent, the tool falls back to artist-name heuristics.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_anthropic_key_here
